{
  "rewrites": [
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/api/webhook-facebook",
      "destination": "/api/app?action=webhook-facebook"
    },
    {
      "source": "/api/tiktok/callback",
      "destination": "/api/tiktok-callback-redirect"
    },
    {
      "source": "/tiktok/webhook",
      "destination": "/api/app?action=webhook-tiktok"
    },
    {
      "source": "/api/tiktok/webhook",
      "destination": "/api/app?action=webhook-tiktok"
    },
    {
      "source": "/api/utils/:endpoint",
      "destination": "/api/utils?endpoint=:endpoint"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/select-facebook-pages",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/youtube-token-refresh",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-scheduled-posts",
      "schedule": "0 6 * * *"
    }
  ]
}

